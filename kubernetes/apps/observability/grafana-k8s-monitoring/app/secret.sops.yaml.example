# 실제 파일 생성: sops kubernetes/apps/observability/grafana-k8s-monitoring/app/secret.sops.yaml
# 값 출처: Grafana Cloud 콘솔 스택 상세 — username은 hosted-metrics/hosted-logs 인스턴스 숫자 ID,
# access-token은 metrics:write + logs:write 스코프의 Access Policy 토큰 (infra/grafana 참고)
---
apiVersion: v1
kind: Secret
metadata:
  name: grafana-cloud-credentials
stringData:
  prometheus-username: "<HOSTED_METRICS_INSTANCE_ID>"
  loki-username: "<HOSTED_LOGS_INSTANCE_ID>"
  access-token: "<GRAFANA_CLOUD_ACCESS_POLICY_TOKEN>"
