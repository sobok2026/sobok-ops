# 실제 파일 생성: sops kubernetes/apps/sobok/web/app/secret.sops.yaml
# APP_POSTGRES_*는 infra/aiven 출력, OTLP 헤더는 Basic base64(인스턴스ID:토큰)
---
apiVersion: v1
kind: Secret
metadata:
  name: web-secrets
stringData:
  APP_POSTGRES_URL: postgres://<USER>:<PASSWORD>@<AIVEN_HOST>:<PORT>/<DB>?sslmode=require
  APP_POSTGRES_CERTIFICATE: |
    -----BEGIN CERTIFICATE-----
    <AIVEN_CA>
    -----END CERTIFICATE-----
  REDIS_URL: rediss://<USER>:<PASSWORD>@<AIVEN_VALKEY_HOST>:<PORT>
  BETTER_AUTH_SECRET: <32자 이상 랜덤>
  OTEL_EXPORTER_OTLP_HEADERS: Authorization=Basic <BASE64_INSTANCE_ID_COLON_TOKEN>
