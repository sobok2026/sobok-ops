# 실제 파일 생성: sops kubernetes/apps/sobok/chat/app/secret.sops.yaml
---
apiVersion: v1
kind: Secret
metadata:
  name: chat-secrets
stringData:
  APP_POSTGRES_URL: postgres://<USER>:<PASSWORD>@<AIVEN_HOST>:<PORT>/<DB>?sslmode=require
  APP_POSTGRES_CERTIFICATE: |
    -----BEGIN CERTIFICATE-----
    <AIVEN_CA>
    -----END CERTIFICATE-----
  REDIS_URL: rediss://<USER>:<PASSWORD>@<AIVEN_VALKEY_HOST>:<PORT>
  PUBSUB_REDIS_URL: rediss://<USER>:<PASSWORD>@<AIVEN_VALKEY_HOST>:<PORT>
  BETTER_AUTH_SECRET: <32자 이상 랜덤 — api와 동일 값>
