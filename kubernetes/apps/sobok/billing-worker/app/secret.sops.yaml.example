# 실제 파일 생성: sops kubernetes/apps/sobok/billing-worker/app/secret.sops.yaml
# PORTONE_API_SECRET이 없으면 잡이 즉시 exit 1로 실패한다
---
apiVersion: v1
kind: Secret
metadata:
  name: billing-worker-secrets
stringData:
  APP_POSTGRES_URL: postgres://<USER>:<PASSWORD>@<AIVEN_HOST>:<PORT>/<DB>?sslmode=require
  APP_POSTGRES_CERTIFICATE: |
    -----BEGIN CERTIFICATE-----
    <AIVEN_CA>
    -----END CERTIFICATE-----
  PORTONE_API_SECRET: <PORTONE_API_SECRET>
  PORTONE_CHANNEL_KEY: <PORTONE_CHANNEL_KEY>
  PORTONE_STORE_ID: <PORTONE_STORE_ID>
  PORTONE_WEBHOOK_SECRET: <PORTONE_WEBHOOK_SECRET>
