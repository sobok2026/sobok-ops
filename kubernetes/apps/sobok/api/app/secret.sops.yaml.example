# 실제 파일 생성: sops kubernetes/apps/sobok/api/app/secret.sops.yaml
# 소셜 로그인(BBATON/GOOGLE/KAKAO)과 PORTONE_*은 기능 활성화 시에만 필요 (미설정 시 해당 기능 비활성)
---
apiVersion: v1
kind: Secret
metadata:
  name: api-secrets
stringData:
  APP_POSTGRES_URL: postgres://<USER>:<PASSWORD>@<AIVEN_HOST>:<PORT>/<DB>?sslmode=require
  APP_POSTGRES_CERTIFICATE: |
    -----BEGIN CERTIFICATE-----
    <AIVEN_CA>
    -----END CERTIFICATE-----
  CHAT_POSTGRES_URL: postgresql://<USER>:<PASSWORD>@<COCKROACH_HOST>:26257/<DB>?sslmode=verify-full
  # CockroachDB가 공인 CA가 아닌 경우에만 (Serverless는 불필요)
  # CHAT_POSTGRES_CERTIFICATE: |
  #   -----BEGIN CERTIFICATE-----
  #   <COCKROACH_CA>
  #   -----END CERTIFICATE-----
  REDIS_URL: rediss://<USER>:<PASSWORD>@<AIVEN_VALKEY_HOST>:<PORT>
  PUBSUB_REDIS_URL: rediss://<USER>:<PASSWORD>@<AIVEN_VALKEY_HOST>:<PORT>
  KAFKA_USERNAME: <AIVEN_KAFKA_USER>
  KAFKA_PASSWORD: <AIVEN_KAFKA_PASSWORD>
  KAFKA_SSL_CA: |
    -----BEGIN CERTIFICATE-----
    <AIVEN_CA>
    -----END CERTIFICATE-----
  BETTER_AUTH_SECRET: <32자 이상 랜덤>
  TURNSTILE_SECRET_KEY: <TURNSTILE_SECRET>
  VAPID_PRIVATE_KEY: <VAPID_PRIVATE_KEY>
  SECRET_ENCRYPTION_KEY: <64자 hex>
  PORTONE_API_SECRET: <PORTONE_API_SECRET>
  PORTONE_CHANNEL_KEY: <PORTONE_CHANNEL_KEY>
  PORTONE_STORE_ID: <PORTONE_STORE_ID>
  PORTONE_WEBHOOK_SECRET: <PORTONE_WEBHOOK_SECRET>
  OTEL_EXPORTER_OTLP_HEADERS: Authorization=Basic <BASE64_INSTANCE_ID_COLON_TOKEN>
