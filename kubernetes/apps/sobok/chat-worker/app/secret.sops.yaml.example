# 실제 파일 생성: sops kubernetes/apps/sobok/chat-worker/app/secret.sops.yaml
---
apiVersion: v1
kind: Secret
metadata:
  name: chat-worker-secrets
stringData:
  APP_POSTGRES_URL: postgres://<USER>:<PASSWORD>@<AIVEN_HOST>:<PORT>/<DB>?sslmode=require
  APP_POSTGRES_CERTIFICATE: |
    -----BEGIN CERTIFICATE-----
    <AIVEN_CA>
    -----END CERTIFICATE-----
  CHAT_POSTGRES_URL: postgresql://<USER>:<PASSWORD>@<COCKROACH_HOST>:26257/<DB>?sslmode=verify-full
  # CockroachDB가 공인 CA가 아닌 경우에만 (Serverless는 불필요)
  # CHAT_POSTGRES_CERTIFICATE: |
  #   -----BEGIN CERTIFICATE-----
  #   <COCKROACH_CA>
  #   -----END CERTIFICATE-----
  PUBSUB_REDIS_URL: rediss://<USER>:<PASSWORD>@<AIVEN_VALKEY_HOST>:<PORT>
  KAFKA_USERNAME: <AIVEN_KAFKA_USER>
  KAFKA_PASSWORD: <AIVEN_KAFKA_PASSWORD>
  KAFKA_SSL_CA: |
    -----BEGIN CERTIFICATE-----
    <AIVEN_CA>
    -----END CERTIFICATE-----
