# 실제 파일 생성: sops kubernetes/apps/sobok/chat-push/app/secret.sops.yaml
---
apiVersion: v1
kind: Secret
metadata:
  name: chat-push-secrets
stringData:
  APP_POSTGRES_URL: postgres://<USER>:<PASSWORD>@<AIVEN_HOST>:<PORT>/<DB>?sslmode=require
  APP_POSTGRES_CERTIFICATE: |
    -----BEGIN CERTIFICATE-----
    <AIVEN_CA>
    -----END CERTIFICATE-----
  KAFKA_USERNAME: <AIVEN_KAFKA_USER>
  KAFKA_PASSWORD: <AIVEN_KAFKA_PASSWORD>
  KAFKA_SSL_CA: |
    -----BEGIN CERTIFICATE-----
    <AIVEN_CA>
    -----END CERTIFICATE-----
  VAPID_PRIVATE_KEY: <VAPID_PRIVATE_KEY>
