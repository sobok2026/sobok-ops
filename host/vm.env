# sobok-1 VM 선언 — run-vm.sh와 watchdog.sh가 source한다
# 수정 후 Mac mini에서 `just host-install`로 재배포한다 (VM 재시작 포함)
VM_NAME=sobok-1
VM_CPUS=10
VM_MEMORY_MIB=12288
VM_DISK_GIB=60

# locally administered MAC — maintenance mode DHCP lease 추적(vm-ip)의 검색 키
VM_MAC=f2:50:b0:0c:00:01
# SMBIOS UUID — 재시작 간 머신 식별자를 고정한다 (최초 1회 uuidgen 값)
VM_UUID=1990d027-00cd-4080-8a7c-6ec656a91980

# vmnet-shared 서브넷 고정 — QEMU 인자로 매 부팅 명시하므로 macOS lease 드리프트와 무관
# start = 게이트웨이(호스트 브리지 IP), start+1..end = DHCP 풀
# 풀이 .2~.9뿐이라 정적 IP .10과 충돌할 수 없다 (bootptab 예약 불필요)
NET_START=192.168.64.1
NET_END=192.168.64.9
NET_MASK=255.255.255.0

# Talos 노드 정적 IP — talos/talconfig.yaml과 일치해야 한다
NODE_IP=192.168.64.10
